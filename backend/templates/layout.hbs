<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{tenant.name}}</title>
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:'Helvetica Neue',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="max-width:520px;background:#ffffff;border:2px solid {{#if tenant.branding.primaryColor}}{{tenant.branding.primaryColor}}{{else}}#1F1F1F{{/if}};border-radius:8px;overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="background:{{#if tenant.branding.primaryColor}}{{tenant.branding.primaryColor}}{{else}}#1F1F1F{{/if}};padding:32px 40px;">
              {{#if tenant.branding.logoUrl}}
                <img src="{{tenant.branding.logoUrl}}" alt="{{tenant.name}}" style="max-height:50px;max-width:180px;margin-bottom:12px;display:block;" />
              {{/if}}
              <h1 style="margin:0;font-size:24px;color:#ffffff;font-weight:700;letter-spacing:-0.5px;">{{tenant.name}}</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:40px;">
              {{{body}}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f5f5f5;padding:24px 40px;border-top:1px solid #e5e5e5;">
              <p style="margin:0;font-size:11px;color:#6b6b6b;line-height:1.5;">
                <strong>{{tenant.name}}</strong>
                {{#if tenant.supportPhone}}<br>Phone: <a href="tel:{{tenant.supportPhone}}" style="color:#6b6b6b;text-decoration:none;">{{tenant.supportPhone}}</a>{{/if}}
                {{#if tenant.supportEmail}}<br>Email: <a href="mailto:{{tenant.supportEmail}}" style="color:#6b6b6b;text-decoration:none;">{{tenant.supportEmail}}</a>{{/if}}
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
