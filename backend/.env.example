MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/flo-sisterlocks
PORT=5000
NODE_ENV=development

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Who receives new-booking alerts — comma-separated for multiple admins
ADMIN_EMAIL=flo@yoursalon.com,secondadmin@yoursalon.com

# The "From" address for outgoing emails.
# For testing use: onboarding@resend.dev (Resend sandbox)
# For production: verify your domain at resend.com → Domains
FROM_EMAIL=onboarding@resend.dev

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# MUST be a mailto: URI (e.g. mailto:admin@example.com)
VAPID_MAILTO=mailto:admin@example.com

# ── Auth (Staff Accounts) ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# Owner (super-admin) PIN — overrides the hardcoded '1234' default
# Change this before going live!
OWNER_PIN=1234

# ── Development Seeding ───────────────────────────────────────────────────────
# Set to 'true' to seed an example attendant (flo / 1234) on first startup
SEED_ATTENDANTS=false
